---
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<svg class={className} viewBox="0 0 8 6" fill="#dc2626" xmlns="http://www.w3.org/2000/svg" style="image-rendering:pixelated" aria-hidden="true">
  <rect x="1" y="0" width="2" height="1" />
  <rect x="5" y="0" width="2" height="1" />
  <rect x="0" y="1" width="8" height="2" />
  <rect x="1" y="3" width="6" height="1" />
  <rect x="2" y="4" width="4" height="1" />
  <rect x="3" y="5" width="2" height="1" />
</svg>
